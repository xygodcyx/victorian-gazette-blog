<div class="article-main" style="margin: 0;">
  <header class="article-header">
    <p class="article-chapter">档案室</p>
    <h1 class="article-title">全部文章</h1>
    <p class="article-subtitle">
      —— 自创刊以来共计 <%= site.posts.length %> 篇文章
    </p>
  </header>

  <div class="ornament-divider">❦ ❦ ❦</div>

  <% var year = 0; %>
  <% page.posts.each(function(post) { %>
    <% var postYear = date(post.date, 'YYYY'); %>
    <% if (postYear !== year) { %>
      <% year = postYear; %>
      <h2 class="list-heading" style="margin-top: 1.5rem;"><%= year %> 年</h2>
    <% } %>

    <article class="story-card" style="margin-bottom: 1rem;">
      <h2 class="story-card-title">
        <a href="<%= url_for(post.path) %>"><%= post.title %></a>
      </h2>
      <div class="story-card-meta">
        <%= date(post.date, config.date_format) %>
        <% if (post.categories && post.categories.length) { %>
          · 栏目：
          <% post.categories.each(function(cat) { %>
            <a href="<%= url_for(cat.path) %>"><%= cat.name %></a>
          <% }); %>
        <% } %>
        <% if (post.tags && post.tags.length) { %>
          ·
          <% post.tags.each(function(tag) { %>
            <a href="<%= url_for(tag.path) %>">#<%= tag.name %></a>
          <% }); %>
        <% } %>
      </div>
    </article>
  <% }); %>

  <%- partial('_partial/pagination') %>
</div>